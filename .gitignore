# NOTE: in .gitignore, a "#" only starts a comment at the BEGINNING of a
# line — text after a pattern becomes part of the pattern and silently
# breaks it. Keep all comments on their own lines.

# --- Pipeline artifacts ------------------------------------------------
# All derived; regenerate with: python pipeline/run_all.py
# (notes.db = local SQLite+sqlite-vec DB; build/ = stage handoff JSONs)
notes.db
build/

# --- Python -------------------------------------------------------------
.venv/
__pycache__/
*.pyc

# --- Frontend -----------------------------------------------------------
# web/public/* are mirrored from the repo root by scripts/copy-assets.js
# before every dev/build — committing them would store everything twice.
web/node_modules/
web/dist/
web/public/pdfs/
web/public/search-index.json

# --- OS noise -----------------------------------------------------------
.DS_Store
